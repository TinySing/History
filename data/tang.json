    {"slug": "li-jing-tang", "name": "李靖", "primaryRole": "general", "roles": ["general", "strategist"], "importance": 90, "birthYear": 571, "deathYear": 649, "aliases": ["卫国公", "李药师"], "summary": "唐朝开国名将，灭东突厥、吐谷浑，著有《李卫公兵法》，是军事家典范。"},
    {"slug": "wu-ze-tian", "name": "武则天", "primaryRole": "emperor", "roles": ["emperor"], "importance": 95, "birthYear": 624, "deathYear": 705, "aliases": ["武曌", "则天大圣皇帝"], "summary": "中国历史上唯一的女皇帝，改国号周。在位期间发展科举，打击门阀，承前启后。"},
    {"slug": "li-long-ji", "name": "李隆基", "primaryRole": "emperor", "roles": ["emperor"], "importance": 85, "birthYear": 685, "deathYear": 762, "aliases": ["唐玄宗", "唐明皇"], "summary": "唐朝第七位皇帝，开创开元盛世，后因宠信杨贵妃、重用安禄山导致安史之乱。"},
    {"slug": "yang-yu-huan", "name": "杨玉环", "primaryRole": "royalty", "roles": ["royalty", "consort"], "importance": 80, "birthYear": 719, "deathYear": 756, "aliases": ["杨贵妃"], "summary": "唐玄宗贵妃，中国古代四大美女之一。安史之乱中在马嵬坡被赐死。"},
    {"slug": "li-bai", "name": "李白", "primaryRole": "poet", "roles": ["poet"], "importance": 100, "birthYear": 701, "deathYear": 762, "aliases": ["诗仙", "李太白", "青莲居士"], "summary": "唐代最伟大的浪漫主义诗人，被尊为「诗仙」。诗风豪放飘逸，代表作《将进酒》《蜀道难》。"},
    {"slug": "du-fu", "name": "杜甫", "primaryRole": "poet", "roles": ["poet"], "importance": 100, "birthYear": 712, "deathYear": 770, "aliases": ["诗圣", "杜工部"], "summary": "唐代最伟大的现实主义诗人，被尊为「诗圣」。诗风沉郁顿挫，代表作《三吏》《三别》。"},
    {"slug": "an-lu-shan", "name": "安禄山", "primaryRole": "rebel", "roles": ["rebel", "general"], "importance": 80, "birthYear": 703, "deathYear": 757, "aliases": ["安禄山"], "summary": "安史之乱的发动者，胡人出身，深得唐玄宗信任。起兵叛乱，攻占洛阳长安。"},
    {"slug": "guo-zi-yi", "name": "郭子仪", "primaryRole": "general", "roles": ["general"], "importance": 90, "birthYear": 697, "deathYear": 781, "aliases": ["汾阳王"], "summary": "唐朝中兴名将，平定安史之乱的主要功臣。单骑退回纥，功高盖主而善终。"},
    {"slug": "yan-zhen-qing", "name": "颜真卿", "primaryRole": "artist", "roles": ["artist", "minister"], "importance": 80, "birthYear": 709, "deathYear": 785, "aliases": ["颜鲁公"], "summary": "唐代书法家，楷书四大家之一。忠义之臣，被叛军杀害。"},
