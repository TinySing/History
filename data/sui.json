  "events": [
    {"slug": "sui-chao-jian-li", "name": "隋朝建立", "timeStart": 581, "aliases": ["杨坚代周"], "summary": "杨坚逼北周静帝禅位，建立隋朝，定都大兴。", "content": "581年杨坚逼北周静帝禅位，建立隋朝，定都大兴（今西安）。杨坚即隋文帝，开始统一全国。"},
    {"slug": "sui-mie-chen", "name": "隋灭陈之战", "timeStart": 589, "aliases": ["统一南北"], "summary": "隋文帝派杨广、杨素等灭陈，俘虏陈后主，统一南北。", "content": "589年隋军渡江灭陈，俘虏陈后主叔宝。自西晋灭亡以来近四百年的分裂局面结束，天下重归一统。"},
    {"slug": "kai-huang-zhi-zhi", "name": "开皇之治", "timeStart": 581, "timeEnd": 604, "aliases": ["隋文帝治世"], "summary": "隋文帝在位期间，政治清明，经济繁荣，人口大增，史称开皇之治。", "content": "隋文帝推行均田制、租庸调制，轻徭薄赋，发展生产。创立三省六部制、科举制，加强中央集权。开皇之治是中国历史上著名的盛世。"},
    {"slug": "da-yun-he", "name": "开凿大运河", "timeStart": 605, "timeEnd": 610, "aliases": ["隋朝大运河"], "summary": "隋炀帝征发百万民夫开凿大运河，连通南北水系，是古代最伟大的水利工程。", "content": "605年至610年，隋炀帝征发百万民夫开凿大运河。运河北起涿郡（北京），南至余杭（杭州），全长两千多公里。大运河促进了南北经济文化交流，但劳民伤财，引发民怨。"},
    {"slug": "ying-jian-dong-du", "name": "营建东都洛阳", "timeStart": 605, "aliases": ["隋炀帝建洛阳"], "summary": "隋炀帝营建东都洛阳，规模宏大，是当时世界上最大的城市之一。", "content": "605年隋炀帝营建东都洛阳，征发民夫数十万。洛阳城规模宏大，布局严整，是当时世界上最大的城市之一。"},
    {"slug": "ke-ju-zhi", "name": "创立科举制", "timeStart": 605, "aliases": ["隋朝科举"], "summary": "隋炀帝创立进士科，科举制正式形成。科举制延续一千三百多年，影响深远。", "content": "605年隋炀帝设进士科，科举制正式形成。科举制打破门第限制，让寒门子弟有出仕机会，延续至清末1905年废除。"},
    {"slug": "san-zheng-gao-ju-li", "name": "三征高句丽", "timeStart": 612, "timeEnd": 614, "aliases": ["隋炀帝征辽"], "summary": "隋炀帝三次亲征高句丽，劳师动众，损失惨重，引发天下大乱。", "content": "612年至614年隋炀帝三次亲征高句丽。第一次出兵一百一十三万，大败而归。三次征伐劳民伤财，天下骚动，农民起义此起彼伏。"},
    {"slug": "sui-mo-nong-min-qi-yi", "name": "隋末农民起义", "timeStart": 613, "timeEnd": 618, "aliases": ["天下大乱"], "summary": "隋炀帝暴政引发大规模农民起义，瓦岗军、窦建德等义军蜂起，隋朝土崩瓦解。", "content": "三征高句丽后，天下大乱。瓦岗军李密、河北窦建德、江淮杜伏威等义军蜂起。618年宇文化及在江都弑杀隋炀帝，隋朝灭亡。"},
    {"slug": "tai-yuan-qi-bing", "name": "太原起兵", "timeStart": 617, "aliases": ["李渊起兵"], "summary": "李渊在太原起兵，攻占长安，立隋炀帝孙杨侑为帝，掌握实权。", "content": "617年太原留守李渊在李世民等人劝说下起兵。李渊进军长安，立代王杨侑为帝，自为大丞相。次年逼杨侑禅位，建立唐朝。"}
  ],
