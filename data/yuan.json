  "events": [
    {"slug": "meng-gu-qi-suo-yuan", "name": "蒙古崛起", "timeStart": 1206, "aliases": ["成吉思汗建国"], "summary": "铁木真统一蒙古各部，建立蒙古帝国。", "content": "1206年铁木真统一蒙古各部，被尊为成吉思汗，建立蒙古帝国。此后蒙古开始大规模扩张。"},
    {"slug": "xi-zheng", "name": "蒙古西征", "timeStart": 1219, "timeEnd": 1260, "aliases": ["三次西征"], "summary": "蒙古帝国三次西征，征服中亚、西亚、东欧，建立横跨欧亚的大帝国。", "content": "蒙古帝国先后三次西征：成吉思汗西征花剌子模，拔都西征欧洲，旭烈兀西征西亚。蒙古铁骑横扫欧亚大陆。"},
    {"slug": "mie-jin-guo", "name": "蒙古灭金", "timeStart": 1234, "aliases": ["金朝灭亡"], "summary": "蒙古与南宋联合灭金，金朝灭亡。", "content": "1234年蒙古与南宋联合攻金，金哀宗自杀，金朝灭亡。此后蒙古开始进攻南宋。"},
    {"slug": "yuan-chao-jian-li", "name": "元朝建立", "timeStart": 1271, "aliases": ["忽必烈称帝"], "summary": "忽必烈改国号为大元，建立元朝。", "content": "1271年忽必烈取《易经》「大哉乾元」之义，改国号为大元，建立元朝，定都大都（今北京）。"},
    {"slug": "mie-nan-song", "name": "元灭南宋", "timeStart": 1276, "timeEnd": 1279, "aliases": ["统一全国"], "summary": "元朝伯颜率军灭南宋，统一全国。崖山之战后南宋灭亡。", "content": "1276年伯颜攻占临安，俘虏宋恭帝。1279年崖山之战，南宋彻底灭亡。元朝统一全国。"},
    {"slug": "xing-sheng-zhi", "name": "行省制", "timeStart": 1271, "aliases": ["元朝行省"], "summary": "元朝创立行省制，是中国省制的开端，影响至今。", "content": "元朝在全国设立行中书省（行省），是中国省制的开端。行省制加强了中央对地方的管理，影响深远。"},
    {"slug": "si-ye-zhi-fa", "name": "四等人制", "timeStart": 1271, "aliases": ["民族压迫"], "summary": "元朝实行四等人制：蒙古人、色目人、汉人、南人，实行民族压迫政策。", "content": "元朝将全国人分为四等：蒙古人最尊贵，色目人次之，汉人（北方汉人）再次，南人（南方汉人）最低。民族压迫政策激化了社会矛盾。"},
    {"slug": "ma-ke-bo-luo-lai-hua", "name": "马可·波罗来华", "timeStart": 1275, "timeEnd": 1292, "aliases": ["马可波罗游记"], "summary": "意大利旅行家马可·波罗在元朝生活十七年，著有《马可·波罗游记》。", "content": "1275年马可·波罗到达元朝，在忽必烈朝廷任职。1292年离开中国，返回意大利后口述《马可·波罗游记》。"},
    {"slug": "shou-shi-li", "name": "编制授时历", "timeStart": 1281, "aliases": ["郭守敬编历"], "summary": "郭守敬编制《授时历》，精度领先世界三百年。", "content": "1281年郭守敬编制《授时历》，一年为365.2425日，与现代公历精度相同，但早了三百年。"},
    {"slug": "hong-jin-jun-qi-yi", "name": "红巾军起义", "timeStart": 1351, "timeEnd": 1368, "aliases": ["元末农民起义"], "summary": "韩山童、刘福通领导的红巾军起义，动摇了元朝统治。朱元璋加入红巾军，最终推翻元朝。", "content": "1351年韩山童、刘福通领导红巾军起义，以白莲教为号召。起义军转战各地，元朝统治土崩瓦解。朱元璋加入红巾军，最终推翻元朝。"},
    {"slug": "ming-chao-jian-li", "name": "明朝建立", "timeStart": 1368, "aliases": ["朱元璋称帝"], "summary": "朱元璋在南京称帝，建立明朝。北伐攻占大都，元朝灭亡。", "content": "1368年朱元璋在南京称帝，建立明朝。徐达北伐攻占大都，元顺帝北逃，元朝灭亡。"}
