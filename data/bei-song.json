  "events": [
    {"slug": "bei-song-jian-li", "name": "北宋建立", "timeStart": 960, "aliases": ["赵匡胤称帝"], "summary": "赵匡胤陈桥兵变，黄袍加身，建立北宋，定都开封。", "content": "960年赵匡胤在陈桥驿发动兵变，黄袍加身，回师开封逼后周恭帝禅位，建立北宋。"},
    {"slug": "bei-jiu-shi-bing-quan", "name": "杯酒释兵权", "timeStart": 961, "aliases": ["解除兵权"], "summary": "赵匡胤通过酒宴威逼利诱，让石守信等大将交出兵权，加强中央集权。", "content": "961年赵匡胤宴请石守信等大将，暗示他们交出兵权。众将次日纷纷辞职，赵匡胤顺利收回兵权。"},
    {"slug": "gao-liang-he-zhi-zhan", "name": "高梁河之战", "timeStart": 979, "aliases": ["宋辽大战"], "summary": "赵光义亲征辽国，在高梁河大败，北宋对辽转为守势。", "content": "979年赵光义亲征辽国，在高梁河（今北京西）被辽军击败，赵光义中箭逃回。从此北宋对辽转为守势。"},
    {"slug": "chan-yuan-zhi-meng", "name": "澶渊之盟", "timeStart": 1005, "aliases": ["宋辽和议"], "summary": "宋真宗亲征澶州，与辽国签订澶渊之盟，以岁币换和平。", "content": "1005年辽军南侵，寇准力主真宗亲征澶州。双方议和，宋每年向辽输银十万两、绢二十万匹，约为兄弟之国。"},
    {"slug": "qing-li-xin-zheng", "name": "庆历新政", "timeStart": 1043, "timeEnd": 1045, "aliases": ["范仲淹改革"], "summary": "范仲淹主持的改革，整顿吏治，发展教育，因保守派反对失败。", "content": "1043年范仲淹任参知政事，推行庆历新政。改革包括整顿吏治、发展教育、加强边防等。因保守派反对，改革仅一年多即失败。"},
    {"slug": "wang-an-shi-bian-fa", "name": "王安石变法", "timeStart": 1069, "timeEnd": 1085, "aliases": ["熙宁变法"], "summary": "王安石主持的全面改革，富国强兵，但触动保守派利益，引发新旧党争。", "content": "1069年王安石任参知政事，推行变法。主要措施包括青苗法、免役法、均输法、市易法等。变法增加了财政收入，但触动保守派利益，引发激烈党争。"},
    {"slug": "yuan-feng-gai-zhi", "name": "元丰改制", "timeStart": 1080, "timeEnd": 1082, "aliases": ["宋神宗改革"], "summary": "宋神宗推行的官制改革，整顿冗官问题。", "content": "宋神宗推行元丰改制，整顿三省六部制，裁减冗官。改革有一定成效，但未能根本解决问题。"},
    {"slug": "jing-kang-zhi-bian", "name": "靖康之变", "timeStart": 1127, "aliases": ["靖康之耻"], "summary": "金军攻破开封，俘虏宋徽宗、宋钦宗，北宋灭亡。", "content": "1127年金军攻破开封，俘虏宋徽宗、宋钦宗及后妃、宗室、大臣三千余人北归。北宋灭亡，史称「靖康之耻」。"},
    {"slug": "nan-song-jian-li", "name": "南宋建立", "timeStart": 1127, "aliases": ["赵构称帝"], "summary": "赵构在南京应天府称帝，建立南宋，偏安江南。", "content": "1127年康王赵构在南京应天府（今商丘）称帝，建立南宋。后定都临安（今杭州），偏安江南。"},
    {"slug": "yue-fei-kang-jin", "name": "岳飞抗金", "timeStart": 1130, "timeEnd": 1142, "aliases": ["岳家军"], "summary": "岳飞率岳家军抗金，郾城大捷，收复襄阳六郡。即将直捣黄龙时被十二道金牌召回。", "content": "岳飞率岳家军抗金，军纪严明，大败金军。郾城大捷中击败金兀术主力。即将直捣黄龙时被十二道金牌召回，后被秦桧以莫须有罪名害死。"},
    {"slug": "shao-xing-he-yi", "name": "绍兴和议", "timeStart": 1141, "aliases": ["宋金和议"], "summary": "南宋与金签订绍兴和议，割地称臣纳贡，岳飞被杀。", "content": "1141年南宋与金签订绍兴和议：宋向金称臣，割让淮河以北，每年纳银二十五万两、绢二十五万匹。岳飞被杀。"}
