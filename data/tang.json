    {"slug": "li-shi-min", "name": "李世民", "primaryRole": "emperor", "roles": ["emperor", "general"], "importance": 100, "birthYear": 598, "deathYear": 649, "aliases": ["唐太宗", "天可汗"], "summary": "唐朝第二位皇帝，贞观之治的开创者。玄武门之变夺位，文治武功卓著，被尊为天可汗。"},
