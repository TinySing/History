  "events": [
    {"slug": "qing-jun-ru-guan", "name": "清军入关", "timeStart": 1644, "aliases": ["满清入关"], "summary": "吴三桂引清军入关，击败李自成，清朝定都北京。", "content": "1644年李自成攻占北京，吴三桂引清军入关。清军击败李自成，定都北京，开始统一全国。"},
    {"slug": "kang-xi-sheng-shi", "name": "康熙盛世", "timeStart": 1661, "timeEnd": 1722, "aliases": ["康熙治世"], "summary": "康熙帝在位六十一年，平三藩、收台湾、亲征噶尔丹，清朝达到鼎盛。", "content": "康熙帝在位期间平定三藩之乱、收复台湾、亲征噶尔丹、签订《尼布楚条约》。康乾盛世由此开始。"},
    {"slug": "ping-san-fan", "name": "平定三藩", "timeStart": 1673, "timeEnd": 1681, "aliases": ["三藩之乱"], "summary": "康熙帝平定吴三桂、尚可喜、耿精忠三藩叛乱，巩固清朝统治。", "content": "1673年吴三桂起兵叛乱，尚可喜、耿精忠响应。康熙帝历时八年平定叛乱，巩固了清朝统治。"},
    {"slug": "shou-fu-tai-wan", "name": "收复台湾", "timeStart": 1683, "aliases": ["施琅收台"], "summary": "施琅率军收复台湾，清朝统一全国。", "content": "1683年施琅率军攻台，郑克塽投降。台湾纳入清朝版图，设台湾府。"},
    {"slug": "ya-pian-zhan-zheng", "name": "鸦片战争", "timeStart": 1840, "timeEnd": 1842, "aliases": ["第一次鸦片战争"], "summary": "英国发动鸦片战争，清朝战败，签订《南京条约》，割让香港，开放五口通商。", "content": "1840年英国以虎门销烟为借口发动鸦片战争。清朝战败，签订《南京条约》，割让香港，赔款2100万银元，开放五口通商。"},
    {"slug": "hu-men-xiao-yan", "name": "虎门销烟", "timeStart": 1839, "aliases": ["林则徐禁烟"], "summary": "林则徐在虎门海滩销毁鸦片两万余箱，显示了中国人民反抗侵略的决心。", "content": "1839年林则徐奉命到广东禁烟，在虎门海滩当众销毁鸦片两万余箱。虎门销烟是鸦片战争的导火索。"},
    {"slug": "tai-ping-tian-guo", "name": "太平天国运动", "timeStart": 1851, "timeEnd": 1864, "aliases": ["太平天国"], "summary": "洪秀全领导太平天国起义，建立政权，占据半壁江山。最终被曾国藩湘军平定。", "content": "1851年洪秀全在金田起义，建立太平天国。太平军席卷东南，定都天京（南京）。1864年被曾国藩湘军平定。"},
    {"slug": "yang-wu-yun-dong", "name": "洋务运动", "timeStart": 1861, "timeEnd": 1895, "aliases": ["自强运动"], "summary": "曾国藩、李鸿章等推行洋务运动，学习西方技术，创办近代企业。", "content": "洋务运动以「自强」「求富」为口号，创办江南制造局、福州船政局等近代企业，建立北洋水师。"},
    {"slug": "jia-wu-zhan-zheng", "name": "甲午战争", "timeStart": 1894, "timeEnd": 1895, "aliases": ["中日甲午"], "summary": "日本发动甲午战争，清朝战败，签订《马关条约》，割让台湾，赔款两亿两白银。", "content": "1894年日本发动甲午战争。清朝战败，签订《马关条约》，割让台湾、辽东半岛（后赎回），赔款两亿两白银。"},
    {"slug": "wu-xu-bian-fa", "name": "戊戌变法", "timeStart": 1898, "aliases": ["百日维新"], "summary": "康有为、梁启超等推动戊戌变法，学习西方制度。变法仅持续一百零三天即失败。", "content": "1898年光绪帝支持康有为等推行变法。慈禧太后发动政变，囚禁光绪，杀害谭嗣同等六君子。"},
    {"slug": "yi-he-tuan-yun-dong", "name": "义和团运动", "timeStart": 1899, "timeEnd": 1901, "aliases": ["庚子事变"], "summary": "义和团运动兴起，八国联军侵华，签订《辛丑条约》。", "content": "1899年义和团运动兴起，打出「扶清灭洋」旗号。1900年八国联军侵华，攻占北京。1901年签订《辛丑条约》，赔款4.5亿两白银。"},
    {"slug": "xin-hai-ge-ming", "name": "辛亥革命", "timeStart": 1911, "aliases": ["武昌起义"], "summary": "孙中山领导的辛亥革命，推翻清朝统治，建立中华民国。", "content": "1911年10月10日武昌起义爆发，各省纷纷响应。1912年1月1日孙中山在南京就任临时大总统，中华民国成立。2月12日清帝退位，清朝灭亡。"},
    {"slug": "qing-di-tui-wei", "name": "清帝退位", "timeStart": 1912, "aliases": ["清朝灭亡"], "summary": "宣统帝溥仪退位，清朝灭亡，中国两千多年的帝制结束。", "content": "1912年2月12日隆裕太后代宣统帝溥仪颁布退位诏书，清朝灭亡。中国两千多年的帝制结束。"}
