  "events": [
    {"slug": "tang-chao-jian-li", "name": "唐朝建立", "timeStart": 618, "aliases": ["李渊称帝"], "summary": "李渊逼隋恭帝禅位，建立唐朝，定都长安。", "content": "618年李渊逼隋恭帝杨侑禅位，建立唐朝，定都长安（今西安）。此后李世民南征北战，统一天下。"},
    {"slug": "xuan-wu-men-zhi-bian", "name": "玄武门之变", "timeStart": 626, "aliases": ["李世民夺位"], "summary": "秦王李世民在玄武门伏杀太子李建成、齐王李元吉，逼李渊退位。", "content": "626年秦王李世民在玄武门设伏，杀死太子李建成、齐王李元吉。李渊被迫立李世民为太子，不久禅位。"},
    {"slug": "zhen-guan-zhi-zhi", "name": "贞观之治", "timeStart": 627, "timeEnd": 649, "aliases": ["唐太宗治世"], "summary": "唐太宗在位期间，政治清明，经济繁荣，社会安定，史称贞观之治。", "content": "唐太宗以隋亡为鉴，虚心纳谏，任用魏征、房玄龄、杜如晦等贤臣。贞观之治是中国历史上最著名的盛世之一。"},
    {"slug": "xuan-zang-xi-xing", "name": "玄奘西行", "timeStart": 629, "timeEnd": 645, "aliases": ["西天取经"], "summary": "玄奘法师西行取经十七年，历经艰险，到达天竺，取回佛经。", "content": "629年玄奘从长安出发，经河西走廊、西域、中亚到达天竺（印度）。在那烂陀寺学习，645年携带大量佛经返回长安。"},
    {"slug": "wu-ze-tian-cheng-di", "name": "武则天称帝", "timeStart": 690, "aliases": ["武周革命"], "summary": "武则天废唐睿宗，改国号周，称则天大圣皇帝，成为中国唯一的女皇帝。", "content": "690年武则天废唐睿宗，改国号为周，称则天大圣皇帝。在位期间发展科举，打击门阀，重用狄仁杰等贤臣。"},
    {"slug": "kai-yuan-sheng-shi", "name": "开元盛世", "timeStart": 713, "timeEnd": 741, "aliases": ["唐玄宗盛世"], "summary": "唐玄宗前期励精图治，任用姚崇、宋璟等贤相，开创开元盛世。", "content": "唐玄宗前期整顿吏治，发展经济，开元盛世是唐朝最繁荣的时期。长安成为当时世界上最大的城市。"},
    {"slug": "an-shi-zhi-luan", "name": "安史之乱", "timeStart": 755, "timeEnd": 763, "aliases": ["安禄山叛乱"], "summary": "安禄山、史思明发动叛乱，攻占洛阳长安，唐朝由盛转衰。", "content": "755年安禄山以讨伐杨国忠为名起兵叛乱，攻占洛阳、长安。唐玄宗逃往四川，杨贵妃在马嵬坡被赐死。763年叛乱平定，但唐朝由盛转衰。"},
    {"slug": "ma-wei-po-bing-bian", "name": "马嵬坡兵变", "timeStart": 756, "aliases": ["杨贵妃之死"], "summary": "安史之乱中唐玄宗逃往四川，途经马嵬坡，禁军哗变，要求处死杨国忠、杨贵妃。", "content": "756年唐玄宗逃离长安，途经马嵬坡。禁军将士饥饿疲惫，哗变杀死杨国忠，要求处死杨贵妃。玄宗被迫赐死杨贵妃。"},
    {"slug": "yong-zhen-ge-xin", "name": "永贞革新", "timeStart": 805, "aliases": ["二王八司马"], "summary": "唐顺宗时期王叔文、王伾领导的改革运动，打击宦官藩镇，失败后参与者被贬。", "content": "805年唐顺宗即位，王叔文、王伾等推行改革，打击宦官势力，削弱藩镇。改革仅持续一百多天即失败，参与者被贬为司马，史称「二王八司马」。"},
    {"slug": "niu-li-dang-zheng", "name": "牛李党争", "timeStart": 808, "timeEnd": 846, "aliases": ["朋党之争"], "summary": "唐朝后期以牛僧孺和李德裕为首的两派官僚争斗四十年，削弱了唐朝统治。", "content": "唐朝后期朝臣分为以牛僧孺为首的牛党和以李德裕为首的李党，两党争斗四十年，互相倾轧。党争削弱了唐朝中央政权。"},
    {"slug": "huang-chao-qi-yi", "name": "黄巢起义", "timeStart": 875, "timeEnd": 884, "aliases": ["黄巢之乱"], "summary": "黄巢领导的农民起义，攻占长安称帝，沉重打击了唐朝统治。", "content": "875年黄巢起兵反唐，880年攻占长安称帝，国号大齐。884年黄巢兵败身死，起义失败。黄巢起义动摇了唐朝统治基础。"},
    {"slug": "zhu-wen-cuan-tang", "name": "朱温篡唐", "timeStart": 907, "aliases": ["唐朝灭亡"], "summary": "朱温逼唐哀帝禅位，建立后梁，唐朝灭亡，五代十国开始。", "content": "907年朱温逼唐哀帝禅位，建立后梁。唐朝灭亡，中国历史进入五代十国时期。"}
