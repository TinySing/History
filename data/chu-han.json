  "events": [
    {
      "slug": "hongmen-banquet",
      "name": "鸿门宴",
      "timeStart": -206,
      "aliases": [
        "鸿门宴"
      ],
      "summary": "秦亡后项羽在鸿门设宴招待刘邦。范增多次示意项羽杀刘邦，项庄舞剑意在沛公，刘邦借故逃脱。这是楚汉之争的关键转折。",
      "content": "前206年，刘邦先入关中，项羽大怒欲攻之。刘邦亲赴鸿门谢罪，项羽设宴款待。\n\n席间范增多次举玦示意，项羽默然不应。范增召项庄舞剑，欲趁机杀刘邦，项伯以身相护。张良急召樊哙闯入，慷慨陈词。刘邦借如厕之机，抄小路逃回营中。\n\n鸿门宴放走刘邦，成为项羽一生最大的失误。",
      "imageUrl": "/images/chu-han/events/hongmen-banquet.svg"
    },
    {
      "slug": "chencang-crossing",
      "name": "暗度陈仓",
      "timeStart": -206,
      "aliases": [
        "明修栈道暗度陈仓"
      ],
      "summary": "韩信献计刘邦，表面上修栈道迷惑项羽，实则暗中从陈仓道出击，一举还定三秦，拉开楚汉之争序幕。",
      "content": "前206年，刘邦被封为汉王，入蜀就国。韩信献计：明修栈道，暗度陈仓。\n\n表面上派兵修复被烧毁的栈道，做出要原路返回的假象。实际上韩信率大军从陈仓小道奇袭，一举击败章邯，还定三秦。\n\n此计为刘邦夺取关中根据地，拉开了楚汉之争的序幕。",
      "imageUrl": "/images/chu-han/events/chencang-crossing.svg"
    },
    {
      "slug": "battle-of-gaixia",
      "name": "垓下之战",
      "timeStart": -202,
      "aliases": [
        "垓下之围",
        "四面楚歌"
      ],
      "summary": "楚汉决战。韩信统三十万大军十面埋伏围困项羽，四面楚歌瓦解楚军斗志。项羽突围至乌江自刎，楚汉之争终结。",
      "content": "前202年，韩信统三十万大军，在垓下（今安徽灵璧）设下十面埋伏，围困项羽。\n\n夜间汉军四面唱起楚歌，楚军将士思乡心切，纷纷逃散。项羽惊呼「汉皆已得楚乎」，知大势已去。夜饮帐中，悲歌慷慨，虞姬自刎。\n\n项羽率八百骑突围，至乌江边，自觉无颜见江东父老，自刎而死，年仅三十一岁。楚汉之争终结，刘邦统一天下。",
      "imageUrl": "/images/chu-han/events/battle-of-gaixia.svg"
    },
    {
      "slug": "backwater-battle",
      "name": "背水一战",
      "timeStart": -204,
      "aliases": [
        "井陉之战"
      ],
      "summary": "韩信率军攻赵，背水列阵置之死地而后生，以少胜多大破赵军二十万，是中国军事史上的经典战例。",
      "content": "前204年，韩信率数万汉军攻赵。赵军二十万据守井陉口，兵力远超汉军。\n\n韩信令部分兵力背水列阵，赵军见状全力出击。汉军无路可退，人人死战。同时韩信派奇兵夺取赵军营寨，遍插汉旗。赵军回望营寨已失，军心大乱，被汉军前后夹击，全军覆没。\n\n「置之死地而后生」的军事思想由此战而来。",
      "imageUrl": "/images/chu-han/events/backwater-battle.svg"
    },
    {
      "slug": "baixia-encirclement",
      "name": "白登之围",
      "timeStart": -200,
      "aliases": [
        "白登之围"
      ],
      "summary": "刘邦亲征匈奴，被冒顿单于三十万骑兵围困于白登山七天七夜。后用陈平计贿赂阏氏才得以脱险。",
      "content": "前200年，刘邦亲率三十二万大军北征匈奴。轻敌冒进，被冒顿单于三十万骑兵围困于白登山（今山西大同）七天七夜。\n\n陈平献计，派人贿赂冒顿阏氏（王后），阏氏劝冒顿撤围，刘邦才得以脱险。此后汉朝对匈奴采取和亲政策，直到汉武帝时才改变。",
      "imageUrl": "/images/chu-han/events/baixia-encirclement.svg"
    }
  ],
